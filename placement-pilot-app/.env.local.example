# Placement Pilot App — Vite environment variables
# Copy this file to .env.local and fill in your values

# Get from lemma.work → your pod URL
VITE_LEMMA_POD_ID=your_pod_id_here

# Lemma API URLs (don't change these)
VITE_LEMMA_API_URL=https://api.lemma.work
VITE_LEMMA_AUTH_URL=https://lemma.work/auth
VITE_LEMMA_APP_BASE_PATH=/

# Get from: lemma org list
VITE_ORG_ID=your_org_id_here

# Get from: lemma connector accounts list --connector gmail
VITE_GMAIL_ACCOUNT_ID=your_gmail_account_id_here
