# Placement Pilot — environment variables
# Copy this file to .env and fill in your credentials

# Get your Pod ID from lemma.work → your pod URL
LEMMA_POD_ID=your_pod_id_here

# Optional: explicit token (not needed if using lemma auth login)
# LEMMA_TOKEN=your_token_here

# Get Gmail account ID after connecting Gmail connector:
# lemma connector accounts list --connector gmail
GMAIL_ACCOUNT_ID=your_gmail_account_id_here
                                                               